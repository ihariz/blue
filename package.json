const express = require("express");
const app = express();

/* ================= HOME ================= */
app.get("/", (req, res) => {
  res.send(`
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>BLUE</title>

<style>
body{
margin:0;
font-family:Arial;
background:#0f172a;
color:white;
text-align:center;
padding-top:80px;
}

.box{
background:#111827;
display:inline-block;
padding:40px;
border-radius:15px;
box-shadow:0 0 20px rgba(59,130,246,0.4);
}

h1{
color:#60a5fa;
}

.status{
margin-top:10px;
padding:6px 12px;
background:#16a34a;
display:inline-block;
border-radius:20px;
font-size:12px;
}
</style>

</head>

<body>

<div class="box">
<h1>💙 BLUE LIVE</h1>
<p>System Running Stable</p>
<div class="status">ONLINE</div>
</div>

</body>
</html>
  `);
});

/* ================= STATUS API ================= */
app.get("/status", (req, res) => {
  res.json({
    project: "BLUE",
    status: "LIVE",
    version: "stable",
    server: "render"
  });
});

/* ================= SERVER START ================= */
const PORT = process.env.PORT || 3000;

app.listen(PORT, () => {
  console.log("BLUE stable running on " + PORT);
});
